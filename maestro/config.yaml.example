# Maestro AI Harness — System Configuration
# Copy to maestro/config.yaml and customize for your environment
# All system config is YAML (this file)
# User content is Markdown: maestro/personas/, maestro/skills/, maestro/scopes/

system:
  # Default provider and model for new conversations
  default_provider: "openai"
  default_model: "gpt-4-turbo"

  # Concurrency and rate limiting
  max_concurrency: 4
  rate_limit_per_minute: 60
  retry_max_attempts: 3

# Provider registry — add, enable, or customize providers here
# Each provider maps to a "kind" (openai, anthropic, ollama, gemini)
# Orchestration routes by kind, not provider name
providers:
  openai:
    kind: "openai"
    endpoint: "https://api.openai.com/v1"
    auth_mode: "bearer"
    auth_env_var: "OPENAI_API_KEY"
    timeout_ms: 30000
    models:
      - name: "gpt-4-turbo"
        context_window: 128000
      - name: "gpt-4"
        context_window: 8192
      - name: "gpt-3.5-turbo"
        context_window: 4096
    capabilities:
      supports_tools: true
      supports_streaming: true
      supports_json_mode: true
      supports_reasoning_controls: true
      max_context_tokens: 128000

  anthropic:
    kind: "anthropic"
    endpoint: "https://api.anthropic.com"
    auth_mode: "bearer"
    auth_env_var: "ANTHROPIC_API_KEY"
    timeout_ms: 30000
    models:
      - name: "claude-3-opus"
        context_window: 200000
      - name: "claude-3-sonnet"
        context_window: 200000
      - name: "claude-3-haiku"
        context_window: 200000
    capabilities:
      supports_tools: true
      supports_streaming: true
      supports_json_mode: false
      supports_reasoning_controls: false
      max_context_tokens: 200000

  ollama:
    kind: "ollama"
    endpoint: "http://localhost:11434"
    auth_mode: "none"
    timeout_ms: 60000
    models:
      - name: "mistral"
        context_window: 32000
      - name: "llama2"
        context_window: 4096
      - name: "neural-chat"
        context_window: 8192
    capabilities:
      supports_tools: false
      supports_streaming: true
      supports_json_mode: false
      supports_reasoning_controls: false
      max_context_tokens: 32000

  gemini:
    kind: "gemini"
    endpoint: "https://generativelanguage.googleapis.com"
    auth_mode: "browser"
    auth_env_var: "GOOGLE_APPLICATION_CREDENTIALS"
    timeout_ms: 30000
    models:
      - name: "gemini-pro"
        context_window: 32768
      - name: "gemini-1.5-pro"
        context_window: 1000000
    capabilities:
      supports_tools: true
      supports_streaming: true
      supports_json_mode: false
      supports_reasoning_controls: false
      max_context_tokens: 1000000

# Optional: custom provider example (add new adapters by kind + factory registration)
