#!/bin/sh
set -eu

install -d -m 0755 /etc/maestro
install -d -m 0755 /var/lib/maestro
install -d -m 0755 /var/log/maestro

if [ ! -f /etc/maestro/config.yaml ]; then
  cat > /etc/maestro/config.yaml <<'EOF'
system:
  default_provider: "ollama"
  default_model: "mistral"
  max_concurrency: 4
  rate_limit_per_minute: 120
  retry_max_attempts: 3

providers:
  ollama:
    kind: "ollama"
    endpoint: "http://127.0.0.1:11434/v1"
    auth_mode: "none"
    timeout_ms: 60000
    models:
      - name: "mistral"
        context_window: 32000
    capabilities:
      supports_tools: false
      supports_streaming: true
      supports_json_mode: false
      supports_reasoning_controls: false
      max_context_tokens: 32000
EOF
  chmod 0644 /etc/maestro/config.yaml
fi

exit 0
